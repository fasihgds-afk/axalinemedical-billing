# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/axalinemedicalbilling?retryWrites=true&w=majority

# Demo mode — login + dashboard without MongoDB (set to false in production)
AUTH_WITHOUT_DB=false
DEV_AUTH_EMAIL=admin@demo.com
DEV_AUTH_PASSWORD=demo1234
DEV_AUTH_NAME=Demo Admin
DEV_AUTH_ROLE=Admin

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# UploadThing v7 (https://uploadthing.com/dashboard → API Keys → V7)
# Option A (recommended): copy the full token from the dashboard
UPLOADTHING_TOKEN=

# Option B: secret + app id (app builds UPLOADTHING_TOKEN automatically)
# UPLOADTHING_SECRET=sk_live_...
# UPLOADTHING_APP_ID=your_app_id
# UPLOADTHING_REGION=sea1

# App URL (used for callbacks in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: default admin for seed script
SEED_ADMIN_EMAIL=admin@axalinemedicalbilling.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Axaline Admin
